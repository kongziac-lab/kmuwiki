# Hermes API server. Generate a strong value, for example:
#   openssl rand -hex 32
API_SERVER_KEY=change-me-generate-32-byte-random-key

# Browser CORS is normally unnecessary because kmuwiki/Hermes integration is
# server-to-server. If direct browser access is needed, use an explicit origin.
API_SERVER_CORS_ORIGINS=

# Bind only to loopback by default. For Tailscale/LAN access, set this to the
# NAS Tailscale IP or a trusted LAN IP and keep DSM firewall rules tight.
HERMES_API_BIND_ADDR=127.0.0.1
HERMES_API_HOST_PORT=8642

# Persistent Hermes state is stored in the Docker named volume `hermes-data`.
HERMES_MEM_LIMIT=2g

# kmuwiki API base. Use either:
#   https://<vercel-app>/api          (Next.js proxy routes)
#   http://<rag-host>:8000           (Python FastAPI directly)
#   https://<vercel-app>/rag         (Vercel service path)
KMUWIKI_API_BASE_URL=https://kmuwiki.example.com/api

# Optional manual override: a Supabase user JWT for a limited PoC account.
# Leave empty when using the automatic dedicated-account login below.
# Do NOT use a service-role key.
KMUWIKI_AUTH_TOKEN=

# Recommended for DS920+ operation: a dedicated limited kmuwiki account.
# The helper signs in to Supabase Auth at call time and uses the returned
# access_token for kmuwiki API requests.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
KMUWIKI_AUTH_EMAIL=hermes-agent@kmu.local
KMUWIKI_AUTH_PASSWORD=

# Optional, only when calling the Python RAG service directly and
# KMU_API_SHARED_SECRET is enabled there.
KMUWIKI_API_SECRET=

# Optional, required only for Hermes chat-completions.
# Set one provider key, then rerun:
#   HERMES_FORCE_RECREATE=1 sh verify-hermes.sh
# OpenRouter is often easiest because it can route multiple models.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# Optional model config synced by deploy/hermes/sync-hermes-env.sh.
# For Gemini API keys, these defaults route Hermes through Google's
# OpenAI-compatible endpoint.
HERMES_MODEL_PROVIDER=gemini
HERMES_MODEL_NAME=gemini-2.5-flash
HERMES_MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
HERMES_MODEL_API_MODE=chat_completions

# Defaults used by the helper script.
KMUWIKI_DEFAULT_K=12
KMUWIKI_DEFAULT_SOURCE_YEAR=
KMUWIKI_DEFAULT_DEPT=
