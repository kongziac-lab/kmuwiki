# 브라우저 노출(공개) — anon 키만. service_role 키는 절대 넣지 말 것.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 — 로컬 개발용 Python 검색·RAG 서비스 URL.
# Vercel Services 배포에서는 RAG_URL이 자동 생성되므로 직접 설정하지 않는다.
PY_API_URL=http://localhost:8000

# 서버 전용 — Python API와 공유하는 남용 방지 시크릿
KMU_API_SHARED_SECRET=

# 로컬 관리자 모드에서만 사용. macOS, Windows 드라이브, NAS UNC 경로 모두 가능.
# 예: /Users/kdh/Documents/KMU-Wiki-Zips
# 예: Z:\KMU-Wiki-Zips
# 예: \\NAS\KMU-Wiki-Zips
KMU_ZIP_DIR=/Users/kdh/Documents/KMU-Wiki-Zips
KMU_ENABLE_LOCAL_INGEST=
KMU_PYTHON_BIN=python3
KMU_INGEST_CWD=

# 선택 강화 — 관리자가 지정할 수 있는 ZIP 폴더를 이 목록(콤마 구분) 하위로 제한.
# 비우면 제한 없음(기존 동작). 예: \\NAS\jdh\kmuwiki,Z:\KMU-Wiki-Zips
KMU_LOCAL_INGEST_ALLOWED_DIRS=
