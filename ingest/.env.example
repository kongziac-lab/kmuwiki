# 입력 ZIP 폴더 (요구사항 1: ZIP을 한 폴더에 누적)
KMU_ZIP_DIR=./zips
KMU_ENV=development
KMU_MAX_ZIP_ENTRY_MB=128
KMU_MAX_ZIP_COMPRESSION_RATIO=200

# 임베딩 (불변식 6: 모델 핀). fake | bge-m3 | cohere
#   개발(DB 없이 검증): fake / fake-deterministic / v1
#   운영(실제 적재·검색): cohere / embed-multilingual-v3.0 / v3  ← 쿼리·문서 동일 모델(1024d) 유지
KMU_EMBED_PROVIDER=fake
KMU_EMBED_MODEL=fake-deterministic
KMU_EMBED_VERSION=v1

# Cohere 키 — 임베딩(embed-multilingual-v3.0)·리랭크·chat 공용. 운영 필수.
COHERE_API_KEY=

# 검색 후보 리랭크(실패 시 하이브리드 결과로 자동 폴백)
KMU_RERANK_PROVIDER=cohere
KMU_RERANK_MODEL=rerank-v3.5

# OCR. easyocr | paddle | none
KMU_OCR_BACKEND=easyocr

# 마스킹 정책 (§7.A): 무엇을 PII로 보고 가릴지.
#   빈 값 = 내부결재문 기본(주민번호·카드·계좌·이메일 마스킹 / 성명·전화·주소 보존)
#   "all" = 전체 마스킹 / 콤마목록 = 직접 지정(예: 민원 문서)
#   예) KMU_MASK_LABELS=주민등록번호,계좌번호,카드번호,이메일,성명,주소
KMU_MASK_LABELS=

# NER (정책이 성명/주소를 가릴 때만 사용). transformers+torch 설치 필요.
KMU_ENABLE_NER=1
KMU_NER_MODEL=Leo97/KoELECTRA-small-v3-modu-ner

# 청킹
KMU_CHUNK_CHARS=1200
KMU_CHUNK_OVERLAP=200

# Supabase (service_role 키는 워커 전용 — 절대 클라이언트/저장소에 노출 금지)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# DB 없이 파이프라인만 검증(1)
KMU_DRY_RUN=0

# 검색 API 남용 방지: 웹 프록시와 Python API에 같은 값을 설정한다.
# 실제 값은 Vercel 환경변수 또는 로컬 .env.local/.env에만 둔다.
KMU_API_SHARED_SECRET=
KMU_API_RATE_LIMIT_PER_MINUTE=30
KMU_PROVIDER_TIMEOUT_SECONDS=120
KMU_API_MAX_BODY_KB=64
KMU_API_MAX_EXPORT_BODY_MB=24
KMU_API_MAX_QUERY_CHARS=1000

# CORS 허용 출처(콤마 구분). 프로덕션에서는 명시값이 필수다.
# 예: https://kmuwiki.vercel.app
KMU_ALLOWED_ORIGINS=

# 답변 생성 LLM. 비워두면 Anthropic 키가 있을 때 Claude, 아니면 Cohere chat을 사용한다.
# nous/gemini는 명시했을 때만 켜진다.
KMU_LLM_PROVIDER=
KMU_COHERE_CHAT_MODEL=command-r-plus-08-2024
ANTHROPIC_API_KEY=
KMU_LLM_MODEL=claude-opus-4-8

# Nous Portal(OpenAI 호환 aggregator) — 탐색/A-B 테스트용.
NOUS_API_KEY=
KMU_NOUS_MODEL=Hermes-4-70B
KMU_NOUS_BASE_URL=https://inference-api.nousresearch.com/v1

# Google Gemini 직접 연결 — 운영 Gemini 사용 시 권장.
# Developer API: GOOGLE_API_KEY 또는 GEMINI_API_KEY 설정.
GOOGLE_API_KEY=
KMU_GEMINI_MODEL=gemini-2.5-pro
# Vertex AI 사용 시 1로 켜고 프로젝트/리전을 지정한다. 기본 리전은 서울(asia-northeast3).
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast3
