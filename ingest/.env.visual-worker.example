# Mac/GPU visual rebuild worker. Copy to a gitignored .env.visual-worker and
# source it before `python -m kmu_ingest.cli reindex-v2`.
KMU_ENV=production
KMU_ZIP_DIR=/Volumes/NAS/kmuwiki/01_raw

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
COHERE_API_KEY=

# Multimodal v2 model pins.
KMU_INDEX_VERSION=v2
KMU_EMBED_PROVIDER=cohere
KMU_EMBED_MODEL=embed-v4.0
KMU_EMBED_VERSION=v4.0-1024
KMU_EMBED_OUTPUT_DIMENSION=1024
KMU_SEARCH_RPC=hybrid_search_v2
KMU_WRITE_LEGACY_INDEX=0

# Local-only extraction and fail-closed visual redaction.
KMU_OCR_BACKEND=paddle
KMU_LAYOUT_BACKEND=ppstructure
KMU_VISUAL_INDEX_ENABLED=1
KMU_VISUAL_REQUIRE_SECURITY_LEVEL=일반
KMU_VISUAL_VERIFY_REDACTION=1
KMU_ENABLE_NER=1
KMU_NER_MODEL=Leo97/KoELECTRA-small-v3-modu-ner

KMU_MAX_VISUAL_PAGES=100
KMU_MAX_ASSETS_PER_DOC=200
KMU_MAX_SEARCH_UNITS_PER_DOC=250
KMU_PROVIDER_TIMEOUT_SECONDS=120
