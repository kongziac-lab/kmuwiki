# KMU Wiki 인제스트 워커(NAS) 전용 최소 시크릿.
#   cp .env.worker.example .env.worker  후 아래 2개만 채운다.
#   .env.worker 는 .gitignore(.env*) 대상 — 저장소/이미지에 절대 커밋하지 않는다.
#
# 최소권한 원칙: NAS 워커는 아래 2개만 필요하다.
#   답변 생성용 키(ANTHROPIC/NOUS/GEMINI/SUPABASE_ANON)는 여기에 넣지 말 것.

# Supabase 적재(워커 전용, RLS 우회 — 최상위 비밀). Synology 암호화 공유폴더에 보관 권장.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# 임베딩(embed-multilingual-v3.0, 1024d). 마스킹된 텍스트만 전송된다.
COHERE_API_KEY=

# 비-root 컨테이너 UID/GID. NAS 공유폴더 ACL에 읽기/쓰기 권한을 부여한다.
KMU_RUN_UID=10001
KMU_RUN_GID=10001
KMU_MAX_ZIP_ENTRY_MB=128
KMU_MAX_ZIP_COMPRESSION_RATIO=200
KMU_PROVIDER_TIMEOUT_SECONDS=120
